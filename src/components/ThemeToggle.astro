---
import { Moon, SunMedium } from '@lucide/astro';
---

<button
  id="theme-toggle"
  class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-slate-800 bg-slate-900/80 text-slate-300 transition hover:border-cyan-400/40 hover:text-white"
  type="button"
  aria-label="切换主题"
  title="切换主题"
>
  <Moon data-theme-icon="dark" size={16} aria-hidden="true" />
  <SunMedium data-theme-icon="claude" class="hidden" size={16} aria-hidden="true" />
</button>
