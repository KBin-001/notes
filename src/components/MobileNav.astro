---
import { getCollection } from 'astro:content';
import { ChevronRight, X } from '@lucide/astro';
import { categoryMeta, categoryOrder, displayTitle, docUrl, getCategoryFromId, isDocInCategory, isIndexDoc, publicDocs, topicDocUrl, topicMeta, topicOrder } from '@/lib/navigation';
import type { TopicId } from '@/lib/navigation';

interface Props {
  currentId?: string;
  currentTopic?: TopicId;
}

const { currentId = 'index', currentTopic } = Astro.props;
const docs = publicDocs(await getCollection('docs'));
const currentCategory = getCategoryFromId(currentId);
const currentDoc = docs.find((doc) => doc.id === currentId);
const currentTopics = currentTopic ? [currentTopic] : currentDoc?.data.topics ?? [];
---

<div id="mobile-nav-overlay" class="fixed inset-0 z-50 hidden bg-black/60 backdrop-blur-sm lg:hidden" data-pagefind-ignore></div>
<aside id="mobile-nav-panel" class="fixed left-0 top-0 z-50 h-full w-[82vw] max-w-sm -translate-x-full overflow-y-auto border-r border-slate-800 bg-slate-950 transition-transform duration-200 lg:hidden" data-pagefind-ignore>
  <div class="sticky top-0 flex h-14 items-center justify-between border-b border-slate-800 bg-slate-950 px-4">
    <span class="text-sm font-semibold text-white">文档目录</span>
    <button id="mobile-nav-close" class="inline-flex h-8 w-8 items-center justify-center rounded-md text-slate-400 hover:bg-slate-900 hover:text-white" type="button" aria-label="关闭导航" title="关闭导航">
      <X size={18} aria-hidden="true" />
    </button>
  </div>
  <nav class="px-4 py-5" aria-label="移动端文档目录">
    <a href="/" class={`mb-4 block rounded-md px-3 py-2 text-sm ${currentId === 'index' ? 'bg-cyan-400/10 text-cyan-100' : 'text-slate-300'}`}>知识库首页</a>
    <p class="mb-2 px-3 text-[11px] font-semibold uppercase tracking-[0.1em] text-slate-600">平台目录</p>
    {categoryOrder.map((category) => {
      const categoryIndex = docs.find((doc) => doc.id === category || doc.id === `${category}/index`);
      const notes = docs
        .filter((doc) => isDocInCategory(doc, category) && !isIndexDoc(doc.id))
        .sort((a, b) => displayTitle(a.data.title).localeCompare(displayTitle(b.data.title), 'zh-CN'));
      const isOpen = currentCategory === category;

      return (
        <details class="group mb-3" data-category-section={category} open={isOpen}>
          <summary
            data-category-summary={category}
            class={`mb-1 flex cursor-pointer list-none items-center gap-2 rounded-md px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em] [&::-webkit-details-marker]:hidden ${isOpen ? 'bg-slate-900 text-slate-100' : 'text-slate-400'}`}
          >
            <ChevronRight
              size={14}
              aria-hidden="true"
              class="shrink-0 transition-transform group-open:rotate-90"
            />
            <span class="min-w-0 flex-1 truncate">{categoryMeta[category]?.title ?? category}</span>
            <span class="text-[11px] text-slate-600">{notes.length}</span>
          </summary>
          <ul class="space-y-1">
            {categoryIndex && (
              <li>
                <a href={docUrl(categoryIndex.id)} class={`block rounded-md px-3 py-2 text-sm ${currentId === categoryIndex.id ? 'bg-cyan-400/10 text-cyan-100' : 'text-slate-400'}`}>
                  分类首页
                </a>
              </li>
            )}
            {notes.map((doc) => (
              <li>
                <a href={docUrl(doc.id)} class={`block rounded-md px-3 py-2 text-sm ${currentId === doc.id ? 'bg-cyan-400/10 text-cyan-100' : 'text-slate-400'}`}>
                  {displayTitle(doc.data.title)}
                </a>
              </li>
            ))}
          </ul>
        </details>
      );
    })}

    <p class="mb-2 mt-6 px-3 text-[11px] font-semibold uppercase tracking-[0.1em] text-slate-600">复盘专题</p>
    {topicOrder.map((topic) => {
      const notes = docs
        .filter((doc) => !isIndexDoc(doc.id) && doc.data.topics.includes(topic))
        .sort((a, b) => displayTitle(a.data.title).localeCompare(displayTitle(b.data.title), 'zh-CN'));
      const isOpen = currentTopics.includes(topic);

      return (
        <details class="group mb-3" data-topic-section={topic} open={isOpen}>
          <summary
            data-topic-summary={topic}
            class={`mb-1 flex cursor-pointer list-none items-center gap-2 rounded-md px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em] [&::-webkit-details-marker]:hidden ${isOpen ? 'bg-slate-900 text-slate-100' : 'text-slate-400'}`}
          >
            <ChevronRight
              size={14}
              aria-hidden="true"
              class="shrink-0 transition-transform group-open:rotate-90"
            />
            <span class="min-w-0 flex-1 truncate">{topicMeta[topic].title}</span>
            <span class="text-[11px] text-slate-600">{notes.length}</span>
          </summary>
          <ul class="space-y-1">
            <li>
              <a href={`/topics/${topic}/`} data-topic-home-link={topic} class={`block rounded-md px-3 py-2 text-sm ${currentTopic === topic ? 'bg-cyan-400/10 text-cyan-100' : 'text-slate-400'}`}>
                专题首页
              </a>
            </li>
            {notes.length === 0 && (
              <li class="px-3 py-2 text-xs text-slate-600">暂无明确归类</li>
            )}
            {notes.map((doc) => (
              <li>
                <a href={topicDocUrl(doc.id, topic)} data-topic-doc-link={topic} class={`block rounded-md px-3 py-2 text-sm ${currentId === doc.id ? 'bg-cyan-400/10 text-cyan-100' : 'text-slate-400'}`}>
                  <span class="block truncate">{displayTitle(doc.data.title)}</span>
                  <span class="text-[11px] text-slate-600">{categoryMeta[doc.data.category]?.title ?? doc.data.category}</span>
                </a>
              </li>
            ))}
          </ul>
        </details>
      );
    })}
  </nav>
</aside>

<script>
  const navOpen = document.getElementById('mobile-nav-open');
  const navClose = document.getElementById('mobile-nav-close');
  const navOverlay = document.getElementById('mobile-nav-overlay');
  const navPanel = document.getElementById('mobile-nav-panel');

  function openNav() {
    navOverlay?.classList.remove('hidden');
    navPanel?.classList.remove('-translate-x-full');
    document.body.classList.add('overflow-hidden');
  }

  function closeNav() {
    navOverlay?.classList.add('hidden');
    navPanel?.classList.add('-translate-x-full');
    document.body.classList.remove('overflow-hidden');
  }

  navOpen?.addEventListener('click', openNav);
  navClose?.addEventListener('click', closeNav);
  navOverlay?.addEventListener('click', closeNav);

</script>
