---
interface Props {
  type?: 'note' | 'warn' | 'danger' | 'tip';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const tone = {
  note: 'callout-note',
  warn: 'callout-warn',
  danger: 'callout-danger',
  tip: 'callout-tip',
};

const labels = {
  note: '注意',
  warn: '提醒',
  danger: '风险',
  tip: '建议',
};
---

<aside class={`callout ${tone[type]}`}>
  <div class="callout-title">{title ?? labels[type]}</div>
  <div class="callout-body">
    <slot />
  </div>
</aside>
