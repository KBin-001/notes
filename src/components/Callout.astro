---
interface Props {
  type?: 'note' | 'warn' | 'danger' | 'tip';
  title?: string;
}

const { type = 'note', title } = Astro.props;

const tone = {
  note: 'border-cyan-400/25 bg-cyan-400/8 text-cyan-100',
  warn: 'border-amber-400/30 bg-amber-400/10 text-amber-100',
  danger: 'border-rose-400/30 bg-rose-400/10 text-rose-100',
  tip: 'border-emerald-400/30 bg-emerald-400/10 text-emerald-100',
};

const labels = {
  note: '注意',
  warn: '提醒',
  danger: '风险',
  tip: '建议',
};
---

<aside class={`my-6 rounded-lg border p-4 ${tone[type]}`}>
  <div class="mb-2 text-sm font-semibold">{title ?? labels[type]}</div>
  <div class="text-sm leading-7 text-slate-200">
    <slot />
  </div>
</aside>
