---
interface Props {
  status: '整理中' | '已验证' | '待验证' | '未完成' | '废弃';
}

const { status } = Astro.props;

const styles = {
  整理中: 'kb-status-active',
  已验证: 'kb-status-verified',
  待验证: 'kb-status-pending',
  未完成: 'kb-status-incomplete',
  废弃: 'kb-status-deprecated',
};
---

<span class={`status-badge inline-flex h-6 items-center whitespace-nowrap rounded-md border px-2 text-xs font-medium ${styles[status]}`}>
  {status}
</span>
