---
interface Props {
  status: '整理中' | '已验证' | '待验证' | '未完成' | '废弃';
}

const { status } = Astro.props;

const styles = {
  整理中: 'border-cyan-400/30 bg-cyan-400/10 text-cyan-200',
  已验证: 'border-emerald-400/30 bg-emerald-400/10 text-emerald-200',
  待验证: 'border-amber-400/30 bg-amber-400/10 text-amber-200',
  未完成: 'border-rose-400/30 bg-rose-400/10 text-rose-200',
  废弃: 'border-slate-500/40 bg-slate-500/10 text-slate-300',
};
---

<span class={`inline-flex h-6 items-center rounded-md border px-2 text-xs font-medium ${styles[status]}`}>
  {status}
</span>
