---
import { Search, X } from '@lucide/astro';
---

<div id="search-dialog" class="fixed inset-0 z-50 hidden items-start justify-center bg-black/55 px-4 pt-20 backdrop-blur-sm" data-pagefind-ignore aria-hidden="true">
  <div class="w-full max-w-2xl rounded-lg border border-slate-800 bg-slate-950 shadow-2xl">
    <div class="flex items-center gap-3 border-b border-slate-800 px-4 py-3">
      <Search size={18} class="text-slate-400" aria-hidden="true" />
      <input
        class="h-10 flex-1 bg-transparent text-sm text-slate-100 outline-none placeholder:text-slate-600"
        placeholder="搜索标题、日志、代码路径..."
        type="search"
      />
      <button id="search-close" class="inline-flex h-8 w-8 items-center justify-center rounded-md text-slate-500 hover:bg-slate-900/70 hover:text-slate-200" type="button" aria-label="关闭搜索" title="关闭">
        <X size={18} aria-hidden="true" />
      </button>
    </div>
    <div id="search-status" class="border-b border-slate-800 px-4 py-3 text-xs text-slate-500">
      输入关键词开始搜索。
    </div>
    <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2"></div>
  </div>
</div>

<script>
  const dialog = document.getElementById('search-dialog');
  const open = document.getElementById('search-open');
  const close = document.getElementById('search-close');
  const input = dialog?.querySelector<HTMLInputElement>('input[type="search"]');
  const status = document.getElementById('search-status');
  const results = document.getElementById('search-results');
  let pagefind: any;
  let searchTimer: number | undefined;

  function setStatus(message: string) {
    if (status) status.textContent = message;
  }

  function clearResults() {
    if (results) results.innerHTML = '';
  }

  async function loadPagefind() {
    if (pagefind) return pagefind;
    try {
      const load = new Function('return import("/pagefind/pagefind.js")') as () => Promise<any>;
      pagefind = await load();
      await pagefind.options({
        excerptLength: 24,
        highlightParam: 'highlight',
      });
      return pagefind;
    } catch {
      setStatus('搜索索引尚未生成。请先运行 npm run build，或访问部署后的站点。');
      return undefined;
    }
  }

  function firstHashUrl(result: any) {
    const subResult = Array.isArray(result.sub_results)
      ? result.sub_results.find((item: any) => typeof item.url === 'string' && item.url.includes('#'))
      : undefined;
    if (subResult?.url) return subResult.url;

    const anchor = Array.isArray(result.anchors) ? result.anchors.find((item: any) => item.id || item.url) : undefined;
    if (anchor?.url) return anchor.url;
    if (anchor?.id) return `${String(result.url).replace(/#.*/, '')}#${anchor.id}`;

    return result.url;
  }

  function renderLink(url: string, className: string, titleHtml: string, excerptHtml?: string) {
    if (!results) return;

    const item = document.createElement('a');
    item.href = url;
    item.className = className;

    const title = document.createElement('div');
    title.className = 'font-medium text-slate-100';
    title.innerHTML = titleHtml;
    item.append(title);

    if (excerptHtml) {
      const excerpt = document.createElement('p');
      excerpt.className = 'mt-1 text-xs leading-6 text-slate-500';
      excerpt.innerHTML = excerptHtml;
      item.append(excerpt);
    }

    results.append(item);
  }

  function renderResult(result: any) {
    const primaryUrl = firstHashUrl(result);
    renderLink(
      primaryUrl,
      'block rounded-md px-3 py-3 text-sm transition hover:bg-slate-900/65',
      result.meta?.title || primaryUrl,
      result.excerpt || result.url,
    );

    if (!Array.isArray(result.sub_results)) return;

    result.sub_results
      .filter((sub: any) => sub.url && sub.url !== primaryUrl)
      .slice(0, 3)
      .forEach((sub: any) => {
        renderLink(
          sub.url,
          'ml-4 block rounded-md border-l border-slate-800 px-3 py-2 text-xs leading-6 text-slate-500 transition hover:bg-slate-900/50 hover:text-slate-300',
          sub.title || sub.excerpt || sub.url,
        );
      });
  }

  async function runSearch(query: string) {
    const keyword = query.trim();
    clearResults();

    if (!keyword) {
      setStatus('输入关键词开始搜索。');
      return;
    }

    const api = await loadPagefind();
    if (!api) return;

    setStatus('搜索中...');
    const search = await api.search(keyword);
    const resultData = await Promise.all(search.results.slice(0, 12).map((result: any) => result.data()));

    clearResults();
    if (resultData.length === 0) {
      setStatus('没有找到匹配结果。');
      return;
    }

    setStatus(`找到 ${search.results.length} 条结果，显示前 ${resultData.length} 条。`);
    resultData.forEach(renderResult);
  }

  function openSearch() {
    dialog?.classList.remove('hidden');
    dialog?.classList.add('flex');
    dialog?.setAttribute('aria-hidden', 'false');
    input?.focus();
    input?.select();
    document.body.classList.add('overflow-hidden');
  }

  function closeSearch() {
    dialog?.classList.add('hidden');
    dialog?.classList.remove('flex');
    dialog?.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('overflow-hidden');
  }

  function scrollToHash(hash: string) {
    const id = decodeURIComponent(hash.slice(1));
    const target = document.getElementById(id) || document.querySelector(hash);
    target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  open?.addEventListener('click', openSearch);
  close?.addEventListener('click', closeSearch);
  input?.addEventListener('input', () => {
    window.clearTimeout(searchTimer);
    searchTimer = window.setTimeout(() => runSearch(input.value), 180);
  });
  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) closeSearch();
  });
  results?.addEventListener('click', (event) => {
    const link = (event.target as HTMLElement).closest<HTMLAnchorElement>('a[href]');
    if (!link) return;

    const target = new URL(link.href);
    closeSearch();

    if (target.origin === location.origin && target.pathname === location.pathname && target.hash) {
      event.preventDefault();
      history.pushState(null, '', `${target.pathname}${target.hash}`);
      scrollToHash(target.hash);
    }
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeSearch();
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      openSearch();
    }
  });
</script>
