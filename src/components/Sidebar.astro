---
import { getCollection } from 'astro:content';
import { ChevronRight } from '@lucide/astro';
import { categoryMeta, categoryOrder, displayTitle, docUrl, getCategoryFromId, getCategoryIndex, getCategoryNotes, getTopicNotes, publicDocs, topicDocUrl, topicMeta, topicOrder } from '@/lib/navigation';
import type { TopicId } from '@/lib/navigation';

interface Props {
  currentId?: string;
  currentTopic?: TopicId;
}

const { currentId = 'index', currentTopic } = Astro.props;
const docs = publicDocs(await getCollection('docs'));
const currentCategory = getCategoryFromId(currentId);
const currentDoc = docs.find((doc) => doc.id === currentId);
const currentTopics = currentTopic ? [currentTopic] : currentDoc?.data.topics ?? [];
---

<aside class="hidden w-72 shrink-0 lg:block" data-pagefind-ignore aria-hidden="true">
  <nav class="sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto px-4 py-6" aria-label="文档目录">
    <a
      href="/"
      class={`sidebar-link mb-4 flex items-center justify-between rounded-md px-3 py-2 text-sm transition ${currentId === 'index' ? 'is-active bg-kb-accent-soft text-kb-heading' : 'text-kb-muted hover:border-kb-border hover:bg-kb-surface-hover hover:text-kb-heading'}`}
    >
      <span>知识库首页</span>
    </a>

    <p class="mb-2 px-3 text-[11px] font-semibold uppercase tracking-[0.1em] text-kb-disabled">平台目录</p>
    {categoryOrder.map((category) => {
      const meta = categoryMeta[category];
      const categoryIndex = getCategoryIndex(docs, category);
      const notes = getCategoryNotes(docs, category);
      const isOpen = currentCategory === category;

      return (
        <details class="group mb-2" data-category-section={category} open={isOpen}>
          <summary
            data-category-summary={category}
            class={`sidebar-summary mb-1 flex cursor-pointer list-none items-center gap-2 rounded-md px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em] transition [&::-webkit-details-marker]:hidden ${isOpen ? 'is-active bg-kb-surface-active text-kb-heading' : 'text-kb-subtle hover:border-kb-border hover:bg-kb-surface-hover hover:text-kb-heading'}`}
          >
            <ChevronRight
              size={14}
              aria-hidden="true"
              class="shrink-0 transition-transform group-open:rotate-90"
            />
            <span class="min-w-0 flex-1 truncate">{meta?.title ?? category}</span>
            <span class="text-[11px] text-kb-disabled">{notes.length}</span>
          </summary>

          <ul
            class="space-y-0.5 overflow-hidden"
          >
            {categoryIndex && (
              <li>
                <a
                  href={docUrl(categoryIndex.id)}
                  class={`sidebar-link block rounded-md px-3 py-1.5 text-sm leading-6 transition ${currentId === categoryIndex.id ? 'is-active bg-kb-accent-soft text-kb-heading' : 'text-kb-muted hover:border-kb-border hover:bg-kb-surface-hover hover:text-kb-heading'}`}
                >
                  分类首页
                </a>
              </li>
            )}
            {notes.map((doc) => {
              const active = currentId === doc.id;
              return (
                <li>
                  <a
                    href={docUrl(doc.id)}
                    class={`sidebar-link block rounded-md px-3 py-1.5 text-sm leading-6 transition ${active ? 'is-active bg-kb-accent-soft text-kb-heading' : 'text-kb-muted hover:border-kb-border hover:bg-kb-surface-hover hover:text-kb-heading'}`}
                  >
                    {displayTitle(doc.data.title)}
                  </a>
                </li>
              );
            })}
          </ul>
        </details>
      );
    })}

    <p class="mb-2 mt-6 px-3 text-[11px] font-semibold uppercase tracking-[0.1em] text-kb-disabled">复盘专题</p>
    {topicOrder.map((topic) => {
      const meta = topicMeta[topic];
      const notes = getTopicNotes(docs, topic);
      const isOpen = currentTopics.includes(topic);

      return (
        <details class="group mb-2" data-topic-section={topic} open={isOpen}>
          <summary
            data-topic-summary={topic}
            class={`sidebar-summary mb-1 flex cursor-pointer list-none items-center gap-2 rounded-md px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em] transition [&::-webkit-details-marker]:hidden ${isOpen ? 'is-active bg-kb-surface-active text-kb-heading' : 'text-kb-subtle hover:border-kb-border hover:bg-kb-surface-hover hover:text-kb-heading'}`}
          >
            <ChevronRight
              size={14}
              aria-hidden="true"
              class="shrink-0 transition-transform group-open:rotate-90"
            />
            <span class="min-w-0 flex-1 truncate">{meta.title}</span>
            <span class="text-[11px] text-kb-disabled">{notes.length}</span>
          </summary>

          <ul class="space-y-0.5 overflow-hidden">
            <li>
              <a
                href={`/topics/${topic}/`}
                data-topic-home-link={topic}
                class={`sidebar-link block rounded-md px-3 py-1.5 text-sm leading-6 transition ${currentTopic === topic ? 'is-active bg-kb-accent-soft text-kb-heading' : 'text-kb-muted hover:border-kb-border hover:bg-kb-surface-hover hover:text-kb-heading'}`}
              >
                专题首页
              </a>
            </li>
            {notes.length === 0 && (
              <li class="px-3 py-1.5 text-xs leading-6 text-kb-disabled">暂无明确归类</li>
            )}
            {notes.map((doc) => {
              const active = currentId === doc.id;
              return (
                <li>
                  <a
                    href={topicDocUrl(doc.id, topic)}
                    data-topic-doc-link={topic}
                    class={`sidebar-link block rounded-md px-3 py-1.5 text-sm leading-6 transition ${active ? 'is-active bg-kb-accent-soft text-kb-heading' : 'text-kb-muted hover:border-kb-border hover:bg-kb-surface-hover hover:text-kb-heading'}`}
                  >
                    <span class="block truncate">{displayTitle(doc.data.title)}</span>
                    <span class="text-[11px] text-kb-disabled">{categoryMeta[doc.data.category]?.title ?? doc.data.category}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </details>
      );
    })}
  </nav>
</aside>
