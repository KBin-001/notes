---
import { ArrowRight, FolderOpen } from '@lucide/astro';

interface Props {
  href: string;
  title: string;
  description: string;
  count?: number;
  accent?: string;
}

const { href, title, description, count = 0, accent = 'cyan' } = Astro.props;

const accentClass: Record<string, string> = {
  cyan: 'kb-accent-cyan',
  emerald: 'kb-accent-emerald',
  violet: 'kb-accent-violet',
  amber: 'kb-accent-amber',
  rose: 'kb-accent-rose',
  sky: 'kb-accent-sky',
  slate: 'kb-accent-slate',
};
---

<a
  href={href}
  class="kb-card group block rounded-lg border border-kb-border kb-card-bg p-5 transition duration-150 hover:border-kb-accent-ring hover:bg-kb-surface-hover"
>
  <div class="mb-5 flex items-center justify-between">
    <div class={`flex h-10 w-10 items-center justify-center rounded-lg ${accentClass[accent] ?? accentClass.cyan}`}>
      <FolderOpen size={19} aria-hidden="true" />
    </div>
    <ArrowRight size={18} class="text-kb-disabled transition group-hover:text-kb-muted" aria-hidden="true" />
  </div>
  <h3 class="text-base font-semibold text-kb-heading">{title}</h3>
  <p class="mt-2 min-h-12 text-sm leading-6 text-kb-muted">{description}</p>
  <p class="mt-5 text-xs text-kb-subtle">{count} 篇笔记</p>
</a>
