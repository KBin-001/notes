---
import { ArrowRight, FolderOpen } from '@lucide/astro';

interface Props {
  href: string;
  title: string;
  description: string;
  count?: number;
  accent?: string;
}

const { href, title, description, count = 0, accent = 'cyan' } = Astro.props;

const accentClass: Record<string, string> = {
  cyan: 'from-cyan-400/12 to-cyan-400/5 text-cyan-300/80',
  emerald: 'from-emerald-400/12 to-emerald-400/5 text-emerald-300/80',
  violet: 'from-violet-400/12 to-violet-400/5 text-violet-300/80',
  amber: 'from-amber-400/12 to-amber-400/5 text-amber-300/80',
  rose: 'from-rose-400/12 to-rose-400/5 text-rose-300/80',
  sky: 'from-sky-400/12 to-sky-400/5 text-sky-300/80',
  slate: 'from-slate-400/12 to-slate-400/5 text-slate-300/80',
};
---

<a
  href={href}
  class="kb-card group block rounded-lg border border-slate-800/90 bg-slate-950/35 p-5 transition duration-150 hover:border-cyan-400/25 hover:bg-slate-900/55"
>
  <div class="mb-5 flex items-center justify-between">
    <div class={`flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br ${accentClass[accent] ?? accentClass.cyan}`}>
      <FolderOpen size={19} aria-hidden="true" />
    </div>
    <ArrowRight size={18} class="text-slate-600 transition group-hover:text-slate-400" aria-hidden="true" />
  </div>
  <h3 class="text-base font-semibold text-white">{title}</h3>
  <p class="mt-2 min-h-12 text-sm leading-6 text-slate-400">{description}</p>
  <p class="mt-5 text-xs text-slate-500">{count} 篇笔记</p>
</a>
