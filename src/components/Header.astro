---
import { BookOpen, Menu, Search } from '@lucide/astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
---

<header class="sticky top-0 z-40 border-b border-slate-800/80 bg-slate-950/80 backdrop-blur" data-pagefind-ignore>
  <div class="mx-auto flex h-14 max-w-[92rem] items-center gap-3 px-4 lg:px-6">
    <button
      id="mobile-nav-open"
      class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-800 text-slate-500 lg:hidden"
      type="button"
      aria-label="打开导航"
      title="打开导航"
    >
      <Menu size={18} aria-hidden="true" />
    </button>

    <a href="/" class="flex min-w-0 items-center gap-2">
      <span class="flex h-8 w-8 items-center justify-center rounded-md bg-cyan-400/8 text-slate-400">
        <BookOpen size={18} aria-hidden="true" />
      </span>
      <span class="truncate text-sm font-semibold text-white sm:text-base">kevin知识库</span>
    </a>

    <div class="flex-1"></div>

    <button
      id="search-open"
      class="inline-flex h-9 min-w-9 items-center justify-center gap-2 rounded-md border border-slate-800 bg-slate-900/70 px-2.5 text-sm text-slate-400 transition hover:border-cyan-400/25 hover:text-slate-200 sm:min-w-56 sm:justify-start"
      type="button"
      aria-label="打开搜索"
      title="搜索"
    >
      <Search size={16} aria-hidden="true" />
      <span class="hidden sm:inline">搜索笔记</span>
      <span class="ml-auto hidden rounded border border-slate-700 px-1.5 py-0.5 text-[11px] text-slate-500 sm:inline">Ctrl K</span>
    </button>
    <ThemeToggle />
  </div>
</header>
