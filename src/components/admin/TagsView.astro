---
import { getCollection } from 'astro:content';
import { isIndexDoc, sortDocsByUpdated, formatDate } from '@/lib/navigation';

const all = await getCollection('docs');
const notes = all.filter((d) => !isIndexDoc(d.id));

const tagMap = new Map<string, { count: number; latest?: Date; category: Set<string> }>();
notes.forEach((doc) => {
  (doc.data.tags || []).forEach((tag) => {
    const entry = tagMap.get(tag) || { count: 0, category: new Set<string>() };
    entry.count += 1;
    entry.category.add(doc.data.category);
    if (!entry.latest || doc.data.updated > entry.latest) entry.latest = doc.data.updated;
    tagMap.set(tag, entry);
  });
});

const tags = Array.from(tagMap.entries())
  .map(([tag, info]) => ({ tag, ...info, cats: Array.from(info.category) }))
  .sort((a, b) => b.count - a.count);
---

<section class="admin-view" data-view="tags">
  <div class="admin-page-head">
    <div class="title-block">
      <h2>标签管理</h2>
      <p>所有笔记中出现的标签聚合（共 {tags.length} 个）。</p>
    </div>
  </div>

  {tags.length === 0 ? (
    <div class="admin-empty">暂无标签</div>
  ) : (
    <div class="admin-card admin-card-pad">
      <div class="admin-flex admin-flex-wrap admin-gap-2">
        {tags.map((t) => (
          <a
            href={`/#/notes`}
            class="admin-tag"
            style="display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius:999px;font-size:0.85rem;background:var(--kb-surface-hover);color:var(--kb-text);text-decoration:none"
            title={`最近更新：${t.latest ? formatDate(t.latest) : '—'}`}
          >
            <span style="font-weight:600">#{t.tag}</span>
            <span class="admin-text-xs admin-subtle">{t.count}</span>
          </a>
        ))}
      </div>
    </div>
  )}
</section>
