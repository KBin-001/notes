---
import AdminSidebar from './AdminSidebar.astro';

interface Props {
  noteCount?: number;
}

const { noteCount = 0 } = Astro.props;
---

<div class="admin-layout" data-admin-layout>
  <header class="admin-header">
    <div class="admin-flex admin-items-center admin-gap-2">
      <button
        class="admin-menu-toggle"
        type="button"
        id="admin-menu-toggle"
        aria-label="打开菜单"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="20" y2="12"></line><line x1="4" y1="18" x2="20" y2="18"></line></svg>
      </button>
      <a href="/#/dashboard" class="admin-brand" data-no-logout>
        <span class="admin-brand-mark">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
        </span>
        <span class="admin-brand-text">
          <span class="name">kevin知识库</span>
          <span class="sub">内容管理后台</span>
        </span>
      </a>
    </div>

    <div class="admin-header-right">
      <div class="admin-user" id="admin-user" hidden>
        <span class="avatar" id="admin-user-avatar">K</span>
        <span id="admin-user-name">—</span>
      </div>
      <a class="admin-btn secondary" id="admin-login-link" href="/api/auth/login" hidden>
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        GitHub 登录
      </a>
      <button class="admin-btn ghost sm" id="admin-logout-btn" type="button" hidden>
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
        退出
      </button>
    </div>
  </header>

  <AdminSidebar noteCount={noteCount} />

  <main class="admin-main">
    <slot />
  </main>
</div>

<!-- 未登录门禁 -->
<div class="admin-gate admin-hidden" id="admin-gate" data-admin-gate>
  <div class="admin-card admin-gate-card">
    <span class="mark">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
    </span>
    <h1>需要登录后使用</h1>
    <p>后台仅对授权账号开放。请使用 GitHub 账号登录后继续，登录会请求仓库读写权限以便管理笔记。</p>
    <a class="admin-btn primary" href="/api/auth/login">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      使用 GitHub 登录
    </a>
    <p class="admin-text-xs admin-subtle admin-mt-4" style="margin-bottom:0">
      <span id="admin-gate-status">正在检查登录状态...</span>
    </p>
  </div>
</div>
