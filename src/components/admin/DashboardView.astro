---
import { getCollection } from 'astro:content';
import {
  FileText,
  FolderTree,
  Tags as TagsIcon,
  Layers,
  CalendarPlus,
  HardDrive,
  Clock3,
  ArrowUpRight,
  CircleAlert,
} from '@lucide/astro';
import ContributionHeatmap from '@/components/ContributionHeatmap.astro';
import StatusBadge from '@/components/StatusBadge.astro';
import {
  categoryMeta,
  categoryOrder,
  displayTitle,
  docUrl,
  formatDate,
  isIndexDoc,
  publicDocs,
  sortDocsByUpdated,
  topicOrder,
} from '@/lib/navigation';

const allDocs = await getCollection('docs');
const notes = allDocs.filter((doc) => !isIndexDoc(doc.id));

// 统计
const tagSet = new Set<string>();
notes.forEach((doc) => (doc.data.tags || []).forEach((tag) => tagSet.add(tag)));
const now = new Date();
const thisMonth = notes.filter((doc) => {
  const d = doc.data.updated;
  return d.getFullYear() === now.getFullYear() && d.getMonth() === now.getMonth();
});

const latest = sortDocsByUpdated(notes).slice(0, 6);

// 待办：状态为 未完成 / 整理中
const todos = sortDocsByUpdated(notes.filter((doc) => doc.data.status === '未完成' || doc.data.status === '整理中')).slice(0, 6);

// 估算存储使用（仅 md/mdx 文本，粗略）
const approxBytes = notes.reduce((sum, doc) => sum + (doc.body?.length || 0), 0);
const storageMb = (approxBytes / 1024 / 1024).toFixed(2);

function editHref(doc: any) {
  const filePath = typeof doc.filePath === 'string' ? doc.filePath.replace(/\\/g, '/') : '';
  const slug = doc.id.split('/').pop()?.replace(/\.(md|mdx)$/i, '') || '';
  const path = filePath || `src/content/docs/${doc.data.category}/${slug}.mdx`;
  return `#/edit?path=${encodeURIComponent(path)}`;
}

const stats = [
  { label: '笔记总数', value: notes.length, hint: '已收录的全部笔记', icon: FileText },
  { label: '分类总数', value: categoryOrder.length, hint: '工作平台 / 模块', icon: FolderTree },
  { label: '标签总数', value: tagSet.size, hint: '去重后的标签', icon: TagsIcon },
  { label: '复盘专题', value: topicOrder.length, hint: '跨平台专题归档', icon: Layers },
  { label: '本月新增', value: thisMonth.length, hint: '本月更新过的笔记', icon: CalendarPlus },
  { label: '存储使用', value: `${storageMb} MB`, hint: '笔记文本估算', icon: HardDrive },
];
---

<section class="admin-view" data-view="dashboard">
  <div class="admin-page-head">
    <div class="title-block">
      <h2>仪表盘</h2>
      <p>欢迎回来，这里是知识库的整体概览与最近动态。</p>
    </div>
    <div class="admin-page-actions">
      <a class="admin-btn secondary" href="#/new">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        新建笔记
      </a>
      <a class="admin-btn primary" href="#/notes">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
        管理笔记
      </a>
    </div>
  </div>

  <!-- 统计卡片 -->
  <div class="admin-stats-grid">
    {stats.map((stat) => (
      <div class="admin-stat-card">
        <span class="stat-icon"><stat.icon size={18} aria-hidden="true" /></span>
        <div class="stat-value">{stat.value}</div>
        <div class="stat-label">{stat.label}</div>
        <div class="stat-hint">{stat.hint}</div>
      </div>
    ))}
  </div>

  <!-- 热力图 + 最近更新 -->
  <div class="admin-mt-4" style="display:grid;grid-template-columns:minmax(0,1fr);gap:22px;margin-top:22px">
    <ContributionHeatmap notes={notes} />
  </div>

  <div style="display:grid;grid-template-columns:minmax(0,1.6fr) minmax(0,1fr);gap:22px;margin-top:22px" data-dashboard-grid>
    <!-- 最近笔记表格 -->
    <div class="admin-card">
      <div class="admin-card-head">
        <h3>
          <Clock3 size={16} aria-hidden="true" />
          最近笔记
        </h3>
        <a class="admin-btn ghost sm" href="#/notes">查看全部
          <ArrowUpRight size={13} aria-hidden="true" />
        </a>
      </div>
      <div class="admin-table-wrap" style="border:none;border-radius:0">
        <table class="admin-table">
          <thead>
            <tr>
              <th>标题</th>
              <th>分类</th>
              <th>状态</th>
              <th>公开</th>
              <th>更新时间</th>
              <th style="text-align:right">操作</th>
            </tr>
          </thead>
          <tbody>
            {latest.map((doc) => (
              <tr>
                <td class="col-title" title={doc.data.title}>{displayTitle(doc.data.title)}</td>
                <td>
                  <span class="admin-tag">{categoryMeta[doc.data.category]?.title ?? doc.data.category}</span>
                </td>
                <td><StatusBadge status={doc.data.status} /></td>
                <td><span class={`admin-vis-badge ${doc.data.visibility}`}>{doc.data.visibility}</span></td>
                <td class="admin-table-meta">{formatDate(doc.data.updated)}</td>
                <td>
                  <div class="col-actions">
                    <a class="admin-icon-btn" href={editHref(doc)} title="编辑" data-edit-path={editHref(doc).split('path=')[1]}>
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                    </a>
                    <a class="admin-icon-btn" href={docUrl(doc.id)} target="_blank" rel="noopener" title="预览">
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                    </a>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- 待办事项 -->
    <div class="admin-card">
      <div class="admin-card-head">
        <h3>
          <CircleAlert size={16} aria-hidden="true" />
          待办事项
        </h3>
        <span class="admin-text-xs admin-subtle">未完成 / 整理中</span>
      </div>
      <div class="admin-card-pad" style="padding:8px">
        {todos.length === 0 ? (
          <div class="admin-empty" style="padding:32px 16px">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block;margin:0 auto 8px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            所有笔记都已整理完成 🎉
          </div>
        ) : (
          <div>
            {todos.map((doc) => (
              <a
                href={editHref(doc)}
                class="admin-flex admin-items-center admin-gap-2"
                style="padding:10px 12px;border-radius:10px;text-decoration:none;border-bottom:1px solid var(--kb-border-subtle)"
              >
                <StatusBadge status={doc.data.status} />
                <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--kb-heading);font-weight:500;font-size:0.88rem">
                  {displayTitle(doc.data.title)}
                </span>
                <span class="admin-text-xs admin-subtle admin-mono">{formatDate(doc.data.updated)}</span>
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </div>
</section>
