---
import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN" data-theme="claude">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>kevin知识库后台</title>
  </head>
  <body class="admin-body" data-pagefind-ignore>
    <main class="admin-shell">
      <section class="admin-topbar">
        <div>
          <p class="eyebrow">kevin知识库</p>
          <h1>笔记上传后台</h1>
        </div>
        <div class="auth-box">
          <span id="auth-status">正在检查登录状态...</span>
          <a id="login-link" class="button primary hidden" href="/api/auth/login">GitHub 登录</a>
          <button id="logout-button" class="button subtle hidden" type="button">退出</button>
        </div>
      </section>

      <section id="admin-app" class="admin-card hidden">
        <div class="tabs" role="tablist">
          <button class="tab active" type="button" data-tab="upload">上传新笔记</button>
          <button class="tab" type="button" data-tab="edit">编辑已有笔记</button>
        </div>

        <div class="panel active" data-panel="upload">
          <label class="file-drop">
            <span>选择 Markdown / MDX 文件</span>
            <input id="file-input" type="file" accept=".md,.mdx,text/markdown,text/x-markdown" />
          </label>
          <p class="hint">上传后会解析 frontmatter 和正文，保存前还可以继续调整字段。</p>
        </div>

        <div class="panel" data-panel="edit">
          <div class="row two">
            <button id="load-list-button" class="button subtle" type="button">读取 GitHub 笔记列表</button>
            <select id="note-list">
              <option value="">先读取列表，再选择文章</option>
            </select>
          </div>
          <p class="hint">编辑模式会更新原文件路径；如需更改 URL，建议新建一篇再删除旧文。</p>
        </div>

        <form id="note-form" class="note-form">
          <div class="target-path" id="target-path">目标路径：等待填写字段</div>

          <div class="row two">
            <label>
              <span>标题</span>
              <input id="title" name="title" required />
            </label>
            <label>
              <span>Slug</span>
              <input id="slug" name="slug" required pattern="[a-z0-9-]+" />
            </label>
          </div>

          <label>
            <span>描述</span>
            <textarea id="description" name="description" rows="2"></textarea>
          </label>

          <div class="row four">
            <label>
              <span>分类</span>
              <select id="category" name="category">
                <option value="mtk">mtk</option>
                <option value="gms">gms</option>
                <option value="camera">camera</option>
                <option value="audio">audio</option>
                <option value="display">display</option>
                <option value="tools">tools</option>
              </select>
            </label>
            <label>
              <span>状态</span>
              <select id="status" name="status">
                <option value="整理中">整理中</option>
                <option value="已验证">已验证</option>
                <option value="待验证">待验证</option>
                <option value="未完成">未完成</option>
                <option value="废弃">废弃</option>
              </select>
            </label>
            <label>
              <span>公开状态</span>
              <select id="visibility" name="visibility">
                <option value="public">public</option>
                <option value="private">private</option>
                <option value="draft">draft</option>
              </select>
            </label>
            <label class="checkbox">
              <input id="sensitive" name="sensitive" type="checkbox" checked />
              <span>sensitive</span>
            </label>
          </div>

          <div class="row two">
            <label>
              <span>创建日期</span>
              <input id="date" name="date" type="date" required />
            </label>
            <label>
              <span>更新日期</span>
              <input id="updated" name="updated" type="date" required />
            </label>
          </div>

          <label>
            <span>标签 tags，用英文逗号分隔</span>
            <input id="tags" name="tags" placeholder="mtk,hall,sensor" />
          </label>

          <fieldset class="topics">
            <legend>复盘专题 topics</legend>
            <label><input type="checkbox" name="topics" value="charging" /> 充电</label>
            <label><input type="checkbox" name="topics" value="camera" /> Camera</label>
            <label><input type="checkbox" name="topics" value="display_tp" /> 屏幕 / TP</label>
            <label><input type="checkbox" name="topics" value="audio" /> 音频</label>
            <label><input type="checkbox" name="topics" value="sensor" /> Sensor</label>
          </fieldset>

          <div class="editor-group">
            <div class="editor-toolbar">
              <span>正文 Markdown / MDX</span>
              <div class="editor-actions">
                <button id="insert-image-button" class="button subtle small" type="button" disabled title="请先填写 Slug">插入图片</button>
              </div>
            </div>
            <textarea id="body" name="body" class="editor" spellcheck="false"></textarea>
            <input id="image-input" type="file" accept="image/png,image/jpeg,image/gif,image/webp,image/svg+xml" multiple class="hidden" />
          </div>

          <div id="warnings" class="warnings hidden"></div>
          <div id="message" class="message hidden"></div>

          <div class="actions">
            <button id="reset-button" class="button subtle" type="button">清空表单</button>
            <button id="save-button" class="button primary" type="submit">提交到 GitHub</button>
          </div>
        </form>
      </section>
    </main>

    <script type="module">
      const state = {
        sha: '',
        path: '',
        mode: 'upload',
      };

      const $ = (selector) => document.querySelector(selector);
      const $$ = (selector) => Array.from(document.querySelectorAll(selector));
      const today = () => new Date().toISOString().slice(0, 10);

      const fields = {
        title: $('#title'),
        description: $('#description'),
        category: $('#category'),
        slug: $('#slug'),
        tags: $('#tags'),
        visibility: $('#visibility'),
        sensitive: $('#sensitive'),
        status: $('#status'),
        date: $('#date'),
        updated: $('#updated'),
        body: $('#body'),
      };

      function showMessage(text, type = 'info') {
        const el = $('#message');
        el.textContent = text;
        el.dataset.type = type;
        el.classList.remove('hidden');
      }

      function showWarnings(warnings = []) {
        const el = $('#warnings');
        if (!warnings.length) {
          el.classList.add('hidden');
          el.textContent = '';
          return;
        }
        el.innerHTML = warnings.map((warning) => `<div>${escapeHtml(warning)}</div>`).join('');
        el.classList.remove('hidden');
      }

      function escapeHtml(value) {
        return String(value).replace(/[&<>"']/g, (char) => ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#039;',
        })[char]);
      }

      async function api(path, options = {}) {
        const response = await fetch(path, options);
        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.ok === false) {
          throw new Error(data.error || `请求失败：${response.status}`);
        }
        return data;
      }

      function setTopics(topics = []) {
        $$('input[name="topics"]').forEach((input) => {
          input.checked = topics.includes(input.value);
        });
      }

      function getTopics() {
        return $$('input[name="topics"]:checked').map((input) => input.value);
      }

      function updateTargetPath() {
        const path = state.sha && state.path
          ? state.path
          : `src/content/docs/${fields.category.value || 'mtk'}/${fields.slug.value || 'new-note'}.mdx`;
        $('#target-path').textContent = `目标路径：${path}`;
        updateImageButton();
      }

      function updateImageButton() {
        const button = $('#insert-image-button');
        const slugValid = /^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$/.test(fields.slug.value.trim());
        button.disabled = !slugValid;
        button.title = slugValid ? '上传图片并插入 Markdown 链接' : '请先填写有效的 Slug';
      }

      function fillForm(note) {
        fields.title.value = note.title || '';
        fields.description.value = note.description || '';
        fields.category.value = note.category || 'mtk';
        fields.slug.value = note.slug || '';
        fields.tags.value = (note.tags || []).join(', ');
        fields.visibility.value = note.visibility || 'public';
        fields.sensitive.checked = note.sensitive !== false;
        fields.status.value = note.status || '整理中';
        fields.date.value = note.date || today();
        fields.updated.value = note.updated || today();
        fields.body.value = note.body || '';
        setTopics(note.topics || []);
        showWarnings(note.warnings || []);
        updateTargetPath();
      }

      function collectNote() {
        return {
          title: fields.title.value.trim(),
          description: fields.description.value.trim(),
          category: fields.category.value,
          slug: fields.slug.value.trim(),
          tags: fields.tags.value.split(',').map((tag) => tag.trim()).filter(Boolean),
          topics: getTopics(),
          visibility: fields.visibility.value,
          sensitive: fields.sensitive.checked,
          status: fields.status.value,
          date: fields.date.value,
          updated: fields.updated.value,
          body: fields.body.value,
          sha: state.sha || undefined,
          path: state.sha ? state.path : undefined,
        };
      }

      function resetForm() {
        state.sha = '';
        state.path = '';
        fields.title.value = '';
        fields.description.value = '';
        fields.category.value = 'mtk';
        fields.slug.value = '';
        fields.tags.value = '';
        fields.visibility.value = 'public';
        fields.sensitive.checked = true;
        fields.status.value = '整理中';
        fields.date.value = today();
        fields.updated.value = today();
        fields.body.value = '';
        setTopics([]);
        showWarnings([]);
        $('#message').classList.add('hidden');
        updateTargetPath();
      }

      function switchTab(tab) {
        state.mode = tab;
        $$('.tab').forEach((button) => button.classList.toggle('active', button.dataset.tab === tab));
        $$('.panel').forEach((panel) => panel.classList.toggle('active', panel.dataset.panel === tab));
        resetForm();
      }

      async function checkAuth() {
        try {
          const data = await api('/api/auth/me');
          $('#auth-status').textContent = `已登录：${data.user.login}`;
          $('#logout-button').classList.remove('hidden');
          $('#login-link').classList.add('hidden');
          $('#admin-app').classList.remove('hidden');
        } catch {
          $('#auth-status').textContent = '需要 GitHub 登录后使用';
          $('#login-link').classList.remove('hidden');
          $('#logout-button').classList.add('hidden');
          $('#admin-app').classList.add('hidden');
        }
      }

      $$('.tab').forEach((button) => button.addEventListener('click', () => switchTab(button.dataset.tab)));

      $('#logout-button').addEventListener('click', async () => {
        await api('/api/auth/logout', { method: 'POST' });
        window.location.reload();
      });

      $('#file-input').addEventListener('change', async (event) => {
        const file = event.target.files?.[0];
        if (!file) return;
        const form = new FormData();
        form.set('file', file);
        showMessage('正在解析文件...');
        try {
          const data = await api('/api/notes/parse', { method: 'POST', body: form });
          state.sha = '';
          state.path = '';
          fillForm(data.note);
          showMessage('解析完成，可以调整字段后提交。', 'success');
        } catch (error) {
          showMessage(error.message, 'error');
        }
      });

      $('#load-list-button').addEventListener('click', async () => {
        showMessage('正在读取 GitHub 笔记列表...');
        try {
          const data = await api('/api/notes/list');
          const select = $('#note-list');
          select.innerHTML = '<option value="">请选择文章</option>' + data.files
            .map((file) => `<option value="${escapeHtml(file.path)}" title="${escapeHtml(file.path)}">${escapeHtml(file.label || file.title || file.path)}</option>`)
            .join('');
          showMessage(`已读取 ${data.files.length} 篇笔记。`, 'success');
        } catch (error) {
          showMessage(error.message, 'error');
        }
      });

      $('#note-list').addEventListener('change', async (event) => {
        const path = event.target.value;
        if (!path) return;
        showMessage('正在读取文章...');
        try {
          const data = await api(`/api/notes/read?path=${encodeURIComponent(path)}`);
          state.sha = data.note.sha || '';
          state.path = data.path;
          fillForm(data.note);
          showMessage('文章已载入，编辑后会更新原文件。', 'success');
        } catch (error) {
          showMessage(error.message, 'error');
        }
      });

      $('#note-form').addEventListener('input', updateTargetPath);

      // Image upload
      $('#insert-image-button').addEventListener('click', () => {
        $('#image-input').click();
      });

      $('#image-input').addEventListener('change', async (event) => {
        const files = Array.from(event.target.files || []);
        if (!files.length) return;

        const button = $('#insert-image-button');
        const originalText = button.textContent;
        button.disabled = true;

        for (let i = 0; i < files.length; i++) {
          const file = files[i];
          button.textContent = `上传中 (${i + 1}/${files.length})...`;
          showMessage(`正在上传图片：${file.name}`);

          try {
            const form = new FormData();
            form.set('file', file);
            form.set('category', fields.category.value);
            form.set('slug', fields.slug.value.trim());

            const data = await api('/api/notes/upload-image', { method: 'POST', body: form });

            // Insert markdown at cursor position
            const textarea = fields.body;
            const cursorPos = textarea.selectionStart;
            const before = textarea.value.substring(0, cursorPos);
            const after = textarea.value.substring(cursorPos);
            const prefix = before.length > 0 && !before.endsWith('\n') ? '\n' : '';
            const suffix = after.length > 0 && !after.startsWith('\n') ? '\n' : '';
            textarea.value = before + prefix + data.markdown + suffix + after;
            textarea.selectionStart = textarea.selectionEnd = cursorPos + prefix.length + data.markdown.length + suffix.length;
            textarea.focus();

            showMessage(`图片已上传：${file.name}`, 'success');
          } catch (error) {
            showMessage(`图片上传失败 (${file.name}): ${error.message}`, 'error');
          }
        }

        button.textContent = originalText;
        updateImageButton();
        event.target.value = '';
      });

      $('#reset-button').addEventListener('click', resetForm);

      $('#note-form').addEventListener('submit', async (event) => {
        event.preventDefault();
        showMessage('正在提交到 GitHub...');
        try {
          const note = collectNote();
          const data = await api('/api/notes/save', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(note),
          });
          state.sha = data.content?.sha || state.sha;
          state.path = data.path || state.path;
          updateTargetPath();
          showMessage(`提交成功：${data.path}`, 'success');
        } catch (error) {
          showMessage(error.message, 'error');
        }
      });

      resetForm();
      checkAuth();
    </script>

    <style>
      :root {
        color-scheme: light;
      }

      .admin-body {
        min-height: 100vh;
        margin: 0;
        background: var(--bg);
        color: var(--text);
      }

      .admin-shell {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0 48px;
      }

      .admin-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        border-bottom: 1px solid var(--border);
        padding-bottom: 18px;
      }

      .eyebrow {
        margin: 0 0 6px;
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 700;
      }

      h1 {
        margin: 0;
        font-size: clamp(1.7rem, 3vw, 2.5rem);
      }

      .auth-box,
      .actions,
      .tabs {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .auth-box {
        color: var(--muted);
        font-size: 0.92rem;
      }

      .admin-card {
        margin-top: 24px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.08);
      }

      .tabs {
        border-bottom: 1px solid var(--border);
        padding: 12px;
      }

      .tab,
      .button {
        border: 1px solid var(--border);
        border-radius: 7px;
        cursor: pointer;
        font: inherit;
        padding: 0.62rem 0.9rem;
        text-decoration: none;
      }

      .tab {
        background: transparent;
        color: var(--muted);
      }

      .tab.active {
        border-color: color-mix(in srgb, var(--accent) 34%, var(--border));
        background: color-mix(in srgb, var(--accent) 11%, transparent);
        color: var(--text);
      }

      .button.primary {
        border-color: color-mix(in srgb, var(--accent) 44%, var(--border));
        background: var(--accent);
        color: var(--accent-contrast);
        font-weight: 700;
      }

      .button.subtle {
        background: var(--surface-2);
        color: var(--text);
      }

      .panel {
        display: none;
        border-bottom: 1px solid var(--border);
        padding: 18px;
      }

      .panel.active {
        display: block;
      }

      .file-drop {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        border: 1px dashed color-mix(in srgb, var(--accent) 40%, var(--border));
        border-radius: 8px;
        background: color-mix(in srgb, var(--accent) 8%, transparent);
        padding: 18px;
      }

      .file-drop span {
        font-weight: 700;
      }

      .hint {
        margin: 10px 0 0;
        color: var(--muted);
        font-size: 0.88rem;
      }

      .note-form {
        display: grid;
        gap: 16px;
        padding: 18px;
      }

      .target-path,
      .message,
      .warnings {
        border: 1px solid var(--border);
        border-radius: 7px;
        background: var(--surface-2);
        color: var(--muted);
        padding: 0.75rem 0.9rem;
        font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
        font-size: 0.86rem;
      }

      .message[data-type='success'] {
        border-color: color-mix(in srgb, var(--accent-2) 38%, var(--border));
        color: var(--text);
      }

      .message[data-type='error'],
      .warnings {
        border-color: color-mix(in srgb, var(--danger) 38%, var(--border));
        color: var(--text);
      }

      .row {
        display: grid;
        gap: 14px;
      }

      .row.two {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .row.four {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      label,
      fieldset {
        display: grid;
        gap: 7px;
        min-width: 0;
      }

      label span,
      legend {
        color: var(--muted);
        font-size: 0.85rem;
        font-weight: 650;
      }

      input,
      select,
      textarea {
        width: 100%;
        box-sizing: border-box;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: var(--bg);
        color: var(--text);
        font: inherit;
        padding: 0.68rem 0.75rem;
      }

      textarea {
        resize: vertical;
      }

      .editor {
        min-height: 440px;
        font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
        font-size: 0.9rem;
        line-height: 1.65;
      }

      .editor-group {
        display: grid;
        gap: 0;
      }

      .editor-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        margin-bottom: 7px;
      }

      .editor-toolbar > span {
        color: var(--muted);
        font-size: 0.85rem;
        font-weight: 650;
      }

      .editor-actions {
        display: flex;
        gap: 8px;
      }

      .button.small {
        padding: 0.35rem 0.7rem;
        font-size: 0.82rem;
      }

      .button:disabled {
        opacity: 0.45;
        cursor: not-allowed;
      }

      .checkbox {
        align-content: end;
        grid-template-columns: auto 1fr;
        gap: 8px;
      }

      .checkbox input {
        width: auto;
      }

      .topics {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 16px;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 12px;
      }

      .topics label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }

      .topics input {
        width: auto;
      }

      .actions {
        justify-content: flex-end;
      }

      .hidden {
        display: none !important;
      }

      @media (max-width: 820px) {
        .admin-topbar,
        .auth-box {
          align-items: flex-start;
          flex-direction: column;
        }

        .row.two,
        .row.four {
          grid-template-columns: 1fr;
        }

        .file-drop {
          align-items: flex-start;
          flex-direction: column;
        }
      }
    </style>
  </body>
</html>
