---
import '../styles/global.css';
import '../styles/admin.css';
import { getCollection } from 'astro:content';
import { isIndexDoc, publicDocs } from '@/lib/navigation';
import AdminShell from '@/components/admin/AdminShell.astro';
import DashboardView from '@/components/admin/DashboardView.astro';
import NotesManageView from '@/components/admin/NotesManageView.astro';
import NoteEditorView from '@/components/admin/NoteEditorView.astro';
import CategoriesView from '@/components/admin/CategoriesView.astro';
import TagsView from '@/components/admin/TagsView.astro';
import TopicsView from '@/components/admin/TopicsView.astro';
import PlaceholderView from '@/components/admin/PlaceholderView.astro';

const allDocs = publicDocs(await getCollection('docs'));
const noteCount = allDocs.filter((d) => !isIndexDoc(d.id)).length;
---

<!doctype html>
<html lang="zh-CN" data-theme="claude">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>kevin知识库 · 后台</title>
  </head>
  <body class="admin-body" data-pagefind-ignore>
    <AdminShell noteCount={noteCount}>
      <!-- 所有视图都在 DOM 中，通过 hash 路由切换显隐 -->
      <DashboardView />
      <NotesManageView />
      <NoteEditorView />
      <CategoriesView />
      <TagsView />
      <TopicsView />
      <PlaceholderView route="storage" />
      <PlaceholderView route="settings" />
      <PlaceholderView route="logs" />
    </AdminShell>

    <script>
      import '@/scripts/admin/app';
    </script>
  </body>
</html>
