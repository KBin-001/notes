---
import { getCollection } from 'astro:content';
import { Clock3, FilePlus2, Wrench } from '@lucide/astro';
import CategoryCard from '@/components/CategoryCard.astro';
import StatusBadge from '@/components/StatusBadge.astro';
import Layout from '@/layouts/Layout.astro';
import { categoryMeta, categoryOrder, displayTitle, docUrl, formatDate, getCategoryNotes, getTopicNotes, isIndexDoc, publicDocs, sortDocsByUpdated, topicMeta, topicOrder } from '@/lib/navigation';

const docs = publicDocs(await getCollection('docs'));
const notes = docs.filter((doc) => !isIndexDoc(doc.id));
const latest = sortDocsByUpdated(notes).slice(0, 6);
---

<Layout title="kevin知识库" description="这里用于沉淀技术笔记、问题复盘、项目记录、工具使用和学习资料。" currentId="index">
  <section class="mx-auto max-w-6xl">
    <div class="kb-hero mb-9 rounded-lg border border-kb-border bg-kb-surface p-6 sm:p-8">
      <h1 class="max-w-3xl text-2xl font-semibold leading-tight text-kb-heading sm:text-3xl">
        把零散问题、学习记录和项目经验，整理成可复用的知识路径。
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-8 text-kb-muted">
        这里用于沉淀技术笔记、问题复盘、项目记录、工具使用和学习资料。
        内容按主题、场景和处理过程归档，方便之后快速查找、复盘和复用。
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="#all-notes" class="kb-button-primary inline-flex h-10 items-center gap-2 rounded-md bg-kb-accent px-4 text-sm font-semibold text-kb-bg transition hover:bg-kb-accent-hover">
          <Wrench size={16} aria-hidden="true" />
          浏览全部笔记
        </a>
        <a href="/templates/issue-template/" class="kb-button-secondary inline-flex h-10 items-center gap-2 rounded-md border border-kb-border-strong px-4 text-sm font-medium text-kb-text transition hover:border-kb-accent-ring hover:text-kb-heading">
          <FilePlus2 size={16} aria-hidden="true" />
          查看整理模板
        </a>
      </div>
    </div>

    <section id="all-notes" class="mb-12 scroll-mt-24">
      <div class="mb-4 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-xl font-semibold text-kb-heading">分类入口</h2>
          <p class="mt-1 text-sm text-kb-subtle">按平台、模块和工作流浏览笔记。</p>
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {categoryOrder.map((category) => {
          const meta = categoryMeta[category];
          const count = getCategoryNotes(docs, category).length;
          return (
            <CategoryCard
              href={`/${category}/`}
              title={meta.title}
              description={meta.description}
              count={count}
              accent={meta.accent}
            />
          );
        })}
      </div>
    </section>

    <section class="mb-12">
      <div class="mb-4 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-xl font-semibold text-kb-heading">复盘专题</h2>
          <p class="mt-1 text-sm text-kb-subtle">同一篇笔记可按明确专题再次归档，便于跨平台复盘。</p>
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {topicOrder.map((topic) => {
          const meta = topicMeta[topic];
          const count = getTopicNotes(docs, topic).length;
          return (
            <CategoryCard
              href={`/topics/${topic}/`}
              title={meta.title}
              description={meta.description}
              count={count}
              accent="amber"
            />
          );
        })}
      </div>
    </section>

    <section class="mb-12 grid gap-5 xl:grid-cols-[1fr_20rem]">
      <div class="kb-panel overflow-hidden rounded-lg border border-kb-border bg-kb-surface">
        <div class="flex items-center gap-2 border-b border-kb-border px-5 py-4">
          <Clock3 size={18} class="text-kb-accent" aria-hidden="true" />
          <h2 class="text-base font-semibold text-kb-heading">最近更新</h2>
        </div>
        <div class="divide-y divide-kb-border-subtle">
          {latest.map((doc) => (
            <a href={docUrl(doc.id)} class="kb-update-link block px-5 py-4 transition hover:bg-kb-surface-hover">
              <div class="flex flex-wrap items-center gap-3">
                <h3 class="font-medium text-kb-text">{displayTitle(doc.data.title)}</h3>
                <StatusBadge status={doc.data.status} />
              </div>
              <p class="mt-2 text-sm leading-6 text-kb-subtle">{doc.data.description}</p>
              <p class="mt-2 text-xs text-kb-disabled">{formatDate(doc.data.updated)} · {categoryMeta[doc.data.category]?.title ?? doc.data.category}</p>
            </a>
          ))}
        </div>
      </div>

      <div class="kb-panel rounded-lg border border-kb-border bg-kb-surface p-5">
        <h2 class="text-base font-semibold text-kb-heading">快速入口</h2>
        <div class="mt-4 grid gap-2">
          {[
            ['MTK 霍尔驱动', '/mtk/hall-driver/'],
            ['ADB TOOL 使用指南', '/tools/adb-tool-guide/'],
            ['MTK debug 关键词', '/tools/mtk-debug-keywords/'],
            ['问题记录模板', '/templates/issue-template/'],
          ].map(([label, href]) => (
            <a href={href} class="kb-quick-link rounded-md border border-kb-border px-3 py-2 text-sm text-kb-muted transition hover:border-kb-accent-ring hover:bg-kb-surface-hover hover:text-kb-heading">
              {label}
            </a>
          ))}
        </div>
      </div>
    </section>
  </section>
</Layout>
