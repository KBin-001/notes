---
import { getCollection, render } from 'astro:content';
import Badge from '@/components/Badge.astro';
import Callout from '@/components/Callout.astro';
import CodeTabs from '@/components/CodeTabs.astro';
import Collapse from '@/components/Collapse.astro';
import StatusBadge from '@/components/StatusBadge.astro';
import TagBadge from '@/components/TagBadge.astro';
import Layout from '@/layouts/Layout.astro';
import { categoryMeta, categoryOrder, displayTitle, docUrl, formatDate, getCategoryNotes, isIndexDoc, publicDocs } from '@/lib/navigation';

export async function getStaticPaths() {
  const entries = await getCollection('docs', ({ id, data }) => id !== 'index' && data.visibility === 'public');
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\/index$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const category = categoryMeta[entry.data.category];
const canonicalUrl = docUrl(entry.id);
const isCategoryPage = isIndexDoc(entry.id) && categoryOrder.includes(entry.data.category);
const docs = isCategoryPage ? publicDocs(await getCollection('docs')) : [];
const categoryNotes = isCategoryPage ? getCategoryNotes(docs, entry.data.category) : [];
---

<Layout title={displayTitle(entry.data.title)} description={entry.data.description} currentId={entry.id} headings={headings}>
  <article class="mx-auto max-w-4xl" data-pagefind-body>
    <header class="mb-8 border-b border-slate-800 pb-6">
      <div class="mb-4 flex flex-wrap items-center gap-2 text-sm text-slate-500">
        <a href="/" class="hover:text-cyan-100">首页</a>
        <span>/</span>
        <a href={`/${entry.data.category}/`} class="hover:text-cyan-100">{category?.title ?? entry.data.category}</a>
        <span>/</span>
        <span>{canonicalUrl}</span>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <StatusBadge status={entry.data.status} />
        <span class="text-xs text-slate-500">创建 {formatDate(entry.data.date)}</span>
        <span class="text-xs text-slate-500">更新 {formatDate(entry.data.updated)}</span>
      </div>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-400">{entry.data.description}</p>
      {entry.data.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <TagBadge tag={tag} />
          ))}
        </div>
      )}
    </header>

    <div class="doc-prose">
      <Content components={{ Badge, Callout, CodeTabs, Collapse, StatusBadge, TagBadge }} />
    </div>

    {isCategoryPage && (
      <section class="mt-12 border-t border-slate-800 pt-8" data-pagefind-ignore>
        <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
          <div>
            <h2 class="text-xl font-semibold text-slate-100">文章列表</h2>
            <p class="mt-1 text-sm text-slate-500">共 {categoryNotes.length} 篇公开笔记。</p>
          </div>
        </div>
        <div class="grid gap-3">
          {categoryNotes.map((doc) => (
            <a href={docUrl(doc.id)} class="block rounded-lg border border-slate-800 bg-slate-950/40 p-4 transition hover:border-cyan-400/25 hover:bg-slate-900/55">
              <div class="flex flex-wrap items-center gap-3">
                <h3 class="min-w-0 flex-1 text-base font-semibold text-slate-100">{displayTitle(doc.data.title)}</h3>
                <StatusBadge status={doc.data.status} />
              </div>
              <p class="mt-2 text-sm leading-6 text-slate-500">{doc.data.description}</p>
              <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-slate-600">
                <span>{formatDate(doc.data.updated)}</span>
                {doc.data.tags.map((tag) => (
                  <TagBadge tag={tag} />
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</Layout>
