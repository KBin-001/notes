---
import { getCollection } from 'astro:content';
import StatusBadge from '@/components/StatusBadge.astro';
import Layout from '@/layouts/Layout.astro';
import { categoryMeta, displayTitle, formatDate, getTopicNotes, publicDocs, topicDocUrl, topicMeta, topicOrder } from '@/lib/navigation';
import type { TopicId } from '@/lib/navigation';

export async function getStaticPaths() {
  return topicOrder.map((topic) => ({
    params: { topic },
    props: { topic },
  }));
}

interface Props {
  topic: TopicId;
}

const { topic } = Astro.props;
const meta = topicMeta[topic];
const docs = publicDocs(await getCollection('docs'));
const notes = getTopicNotes(docs, topic);
---

<Layout title={meta.title} description={meta.description} currentTopic={topic}>
  <section class="mx-auto max-w-[52rem]">
    <header class="article-header mb-9 border-b border-slate-800 pb-7">
      <div class="breadcrumb mb-4 flex flex-wrap items-center gap-2 text-sm text-slate-500">
        <a href="/" class="hover:text-cyan-100">首页</a>
        <span>/</span>
        <span>复盘专题</span>
        <span>/</span>
        <span>{meta.title}</span>
      </div>
      <p class="mb-3 text-sm font-medium text-cyan-200">复盘专题</p>
      <h1 class="text-3xl font-semibold leading-tight text-white sm:text-4xl">{meta.title}</h1>
      <p class="mt-4 max-w-3xl text-base leading-7 text-slate-400">{meta.description}</p>
      <p class="mt-4 text-xs text-slate-600">共 {notes.length} 篇明确归类笔记</p>
    </header>

    <div class="grid gap-3">
      {notes.length === 0 && (
        <div class="kb-panel rounded-lg border border-slate-800 bg-slate-950/45 p-5 text-sm text-slate-500">
          目前没有明确归入该专题的笔记。
        </div>
      )}
      {notes.map((doc) => (
        <a href={topicDocUrl(doc.id, topic)} class="kb-list-card block rounded-lg border border-slate-800 bg-slate-950/45 p-5 transition hover:border-cyan-400/35 hover:bg-slate-900/70">
          <div class="flex flex-wrap items-center gap-3">
            <h2 class="min-w-0 flex-1 text-base font-semibold text-slate-100">{displayTitle(doc.data.title)}</h2>
            <StatusBadge status={doc.data.status} />
          </div>
          <p class="mt-2 text-sm leading-6 text-slate-500">{doc.data.description}</p>
          <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-slate-600">
            <span>{formatDate(doc.data.updated)}</span>
            <span>/</span>
            <span>{categoryMeta[doc.data.category]?.title ?? doc.data.category}</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
